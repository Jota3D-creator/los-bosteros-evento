<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Los Bosteros en Valencia - Evento</title>
  <link rel="stylesheet" href="style.css" />
</head>
<body>
  <main class="container">
    <section class="hero">
      <h1>Los Bosteros en Valencia</h1>
      <h2>Próximo encuentro xeneize</h2>
      <p class="date">Fecha: domingo XX de XXXX</p>
      <p class="place">Lugar: Hard Rock Cafe Valencia</p>
      <p class="price">Entrada: 5 €</p>

      <a class="button" href="PEGAR_LINK_DEL_FORMULARIO" target="_blank">
        Anotarme al evento
      </a>

      <a class="button secondary" href="PEGAR_LINK_DE_PAGO_O_INFO" target="_blank">
        Ver cómo pagar
      </a>
